# ============================================================================
# Hestia site configuration — copy to `hestia.env` and fill in your values.
#
#   cp config/hestia.env.example config/hestia.env
#   $EDITOR config/hestia.env
#
# The install scripts and the runtime shell scripts source this file. Values are
# plain `KEY=value` (no spaces around `=`; quote values with spaces).
#
# NOTHING SECRET GOES HERE. The Telegram bot token is a secret and lives ONLY in
# the broker's 0600 EnvironmentFile (see docs/configuration.md), never in this
# file and never committed. `hestia.env` itself is .gitignore'd anyway.
# ============================================================================

# ---------------------------------------------------------------------------
# 1) OWNER IDENTITY (Telegram)  — REQUIRED
# ---------------------------------------------------------------------------
# Your numeric Telegram user id (NOT a username). Get it by messaging @userinfobot.
# The broker honors approval taps ONLY from this id. 0 = fail-closed (matches nobody).
HESTIA_OWNER_ID=0

# ---------------------------------------------------------------------------
# 2) THE TARGET MACHINE (the laptop/host the agent acts on, over Tailscale SSH) — REQUIRED
# ---------------------------------------------------------------------------
# The restricted unix user the broker runs commands as, @ the target's Tailscale
# host (MagicDNS name or 100.x tailnet IP). Created by install/target/1-users.sh.
HESTIA_TARGET_HOST=hestia-agent@your-laptop.your-tailnet.ts.net

# The OWNER's own unix account on the target machine. ELEVATED (owner-approved)
# commands run AS this user, reaching your private files. Must be a real account
# on the target. Rendered into the elevated wrapper's allowlist at install.
# REQUIRED only if you want the elevation feature.
OWNER_UNIX_USER=

# Optional: your tailnet IPs, used ONLY by the firewall backstop self-test to
# prove the box cannot reach them. Leave blank to skip those probes.
HOMESERVER_TAILSCALE_IP=
TARGET_TAILSCALE_IP=

# ---------------------------------------------------------------------------
# 3) THE CONFINED-AGENT CONTAINER (Phase 1)
# ---------------------------------------------------------------------------
CONTAINER_NAME=hestia-box          # LXD container that runs your agent
AGENT_BOX_USER=hestia              # the agent's unix user inside the container
HESTIA_BRIDGE=lxdbr0               # the LXD bridge the container is on

# Optional bridge-addressing overrides. The egress firewall AUTO-DETECTS these
# from the live bridge; set them only if detection fails.
# CONTAINER_SUBNET_V4=10.x.y.0/24
# LXDBR_GW4=10.x.y.1
# CONTAINER_SUBNET_V6=fd42:...::/64
# LXDBR_GW6=fd42:...::1

# ---------------------------------------------------------------------------
# 4) THE AGENT'S MODEL PROVIDER (Phase 1 — used to render the agent config)
# ---------------------------------------------------------------------------
# Any OpenAI-compatible endpoint. An open-weight model is recommended for a
# self-hosted personal agent. These are NOT secrets (the API key is an env var).
LLM_BASE_URL=https://your-openai-compatible-endpoint.example/v1
LLM_API_KEY_ENV=OPENAI_API_KEY     # name of the env var holding the API key
MODEL_NAME=your-model-name

# ---------------------------------------------------------------------------
# 5) BROKER TUNING (optional — sensible defaults baked in)
# ---------------------------------------------------------------------------
# HESTIA_SESSION_SECS=600          # open-window duration (per owner-approved session)
# HESTIA_CMD_SECS=180              # per-command approval timeout (auto-deny after)
# HESTIA_SESSION_ASK_SECS=300      # session-open button timeout
# HESTIA_EXEC_TIMEOUT=120          # max seconds a single relayed command may run
# HESTIA_MAX_INFLIGHT=6            # concurrent relayed commands cap
# HESTIA_MAX_PENDING=20            # outstanding approval buttons cap
# HESTIA_SESSION_CMD_BUDGET=40     # commands allowed per open window

# ---------------------------------------------------------------------------
# 6) FIXED DESIGN CONSTANTS (change only if you know why)
# ---------------------------------------------------------------------------
# The free-zone workspace on the target — the ONLY place free-zone (un-buttoned)
# commands may read. Must match on the broker and the target executor.
WORKSPACE=/srv/projects
